{
  "name": "momentovino",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:web": "turbo run dev --filter=web",
    "dev:web:with-flask": "pnpm --filter web dev:with-flask",
    "dev:mobile": "turbo run dev --filter=mobile",
    "mobile:start": "pnpm --filter mobile exec expo start",
    "mobile:prebuild": "pnpm --filter mobile exec expo prebuild --platform ios --clean",
    "mobile:ios": "pnpm --filter mobile exec expo run:ios",
    "mobile:xcode": "open apps/mobile/ios/MomentoVino.xcworkspace",
    "ios": "pnpm --filter mobile ios",
    "android": "pnpm --filter mobile android"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
