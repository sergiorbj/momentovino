# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for family invite links in emails (web or universal link). Falls back to momentovino:// if unset.
PUBLIC_APP_URL=http://localhost:3000

# Resend (family invite emails from Python API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MomentoVino <onboarding@resend.dev>
# Set to true to skip sending email and only log the invite URL (dev without Resend domain).
RESEND_SKIP_SEND=false

# Sign in with Apple — token revocation on account deletion (api/_apple.py).
# Required by App Store Guideline 5.1.1(v). If these are left blank, account
# deletion still works fully — only the Apple-side token revocation is skipped.
# Create a "Sign in with Apple" key at developer.apple.com > Certificates,
# Identifiers & Profiles > Keys; that gives you the Key ID and the .p8 file.
APPLE_TEAM_ID=your-10-char-apple-team-id
APPLE_KEY_ID=your-p8-key-id
# Contents of the .p8 file. Paste the whole PEM; newlines may be written as \n.
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# App bundle identifier. Optional — defaults to com.momentovino.app if unset.
APPLE_CLIENT_ID=com.momentovino.app
