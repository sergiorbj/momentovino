# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for family invite links in emails (web or universal link). Falls back to momentovino:// if unset.
PUBLIC_APP_URL=http://localhost:3000

# Resend (family invite emails from Python API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MomentoVino <onboarding@resend.dev>
# Set to true to skip sending email and only log the invite URL (dev without Resend domain).
RESEND_SKIP_SEND=false
