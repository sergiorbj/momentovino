# Supabase
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# API (Next.js `apps/web`, default port 3000)
# On a physical phone, localhost is the phone itself — keep this value: in __DEV__ the app
# rewrites localhost/127.0.0.1 to your computer's LAN IP from Metro. In apps/web run
# `pnpm dev:lan` so Next listens on the LAN (not only localhost).
# Override with a full URL if you use another host/port or tunnel, e.g. https://xxx.ngrok.io/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api
