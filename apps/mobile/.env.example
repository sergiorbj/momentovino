# Supabase
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# API (Next.js `apps/web`, default port 3000). Origin (without `/api`) is used for
# password-reset redirect → `<origin>/auth/reset-callback`; add that full URL in
# Supabase → Authentication → Redirect URLs.
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# RevenueCat (paywall)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google sign-in
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# EAS CLI App Store Connect.
EXPO_APPLE_ID=